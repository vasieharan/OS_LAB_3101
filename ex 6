#include <stdio.h>
#include <pthread.h>
#include <semaphore.h>
#include <stdlib.h>

sem_t mutex;
int shared_resource = 0;

void *thread_function(void *arg)
{
    int i, val;
    long thread_id = (long)arg;

    for (i = 0; i < 5; i++)
    {
        sem_wait(&mutex);   // lock

        val = shared_resource;
        printf("Thread %ld: Read %d from shared resource\n", thread_id, val);

        val++;
        printf("Thread %ld: Writing %d to shared resource\n", thread_id, val);

        shared_resource = val;

        sem_post(&mutex);   // unlock
    }

    pthread_exit(NULL);
}

int main()
{
    pthread_t threads[3];
    int i, ret;

    sem_init(&mutex, 0, 1);

    for (i = 0; i < 3; i++)
    {
        ret = pthread_create(&threads[i], NULL, thread_function, (void *)(long)i);
        if (ret != 0)
        {
            perror("pthread_create failed");
            return -1;
        }
    }

    for (i = 0; i < 3; i++)
    {
        ret = pthread_join(threads[i], NULL);
        if (ret != 0)
        {
            perror("pthread_join failed");
            return -1;
        }
    }

    printf("\nFinal value of shared resource: %d\n", shared_resource);

    sem_destroy(&mutex);

    return 0;
}
